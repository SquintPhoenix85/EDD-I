<UserControl x:Class="RestaurantApp.Views.PlatosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>

        <!-- Estilo para TextBox -->
        <Style x:Key="CustomTextBoxStyle" TargetType="TextBox">

            <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="3"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>

            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#33D4A373" Offset="0"/>
                        <GradientStop Color="#66D4A373" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="#66D4A373"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">

                                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Stretch"/>           
                        </Border>


                    <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#4CD4A373" Offset="0"/>
                                            <GradientStop Color="#80D4A373" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                        
                            <!-- Focus -->
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#66D4A373" Offset="0"/>
                                            <GradientStop Color="#99D4A373" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>

        <!-- Estilo Personalizado para Filas del DataGrid -->
        <Style x:Key="CustomRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#2D2D2D"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                        <Border x:Name="DG_RowBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#CCCCCC"
                                BorderThickness="0,0,0,1"
                                Padding="0">
                            <SelectiveScrollingGrid>
                                <SelectiveScrollingGrid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </SelectiveScrollingGrid.ColumnDefinitions>

                                <SelectiveScrollingGrid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </SelectiveScrollingGrid.RowDefinitions>

                                <DataGridCellsPresenter Grid.Column="1" ItemsPanel="{TemplateBinding ItemsPanel}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </SelectiveScrollingGrid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <!-- Cuando está seleccionado -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="DG_RowBorder" Property="Background" Value="#6F4E37"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>

                            <!-- Cuando está en hover (mouse sobre) -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DG_RowBorder" Property="Background" Value="#D4A373"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>

                            <!-- Cuando está seleccionado Y en hover -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="DG_RowBorder" Property="Background" Value="#5A3D2A"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Lista de platos -->
        <GroupBox Header="Lista de Platos"
                  Grid.Column="0"
                  Margin="0,0,5,0"
                  FontFamily="/Fonts/#Poppins"
                  FontWeight="Bold">

            <DataGrid
                ItemsSource="{Binding Platos}"
                SelectedItem="{Binding SelectedPlato}"  
                AutoGenerateColumns="False"
                IsReadOnly="True"
                SelectionChanged="DataGrid_SelectionChanged" Foreground="#FF424040">
                
                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" Foreground="{StaticResource TextColor}" />

                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>

                    <DataGridTextColumn Header="Precio"
                                        Binding="{Binding Precio, StringFormat=C}"
                                        Width="100"/>

                    <DataGridTextColumn Header="Disponible"
                                        Binding="{Binding Disponible}"
                                        Width="80"/>

                </DataGrid.Columns>

            </DataGrid>

        </GroupBox>

        <!-- Formulario -->
        <GroupBox Header="Gestión de Plato"
                  Grid.Column="1"
                  FontFamily="/Fonts/#Poppins"
                  FontWeight="Bold">

            <StackPanel Margin="10">

                <Label Content="Nombre:"
                       Foreground="{StaticResource TextColor}"
                       FontWeight="Regular"/>

                <TextBox
                    Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"
                    Style="{StaticResource CustomTextBoxStyle}"
                    Margin="0,0,0,10"/>

                <Label Content="Precio:"
                       Foreground="{StaticResource TextColor}"
                       FontWeight="Regular"/>

                <TextBox
                    Text="{Binding Precio, UpdateSourceTrigger=PropertyChanged}"
                    Style="{StaticResource CustomTextBoxStyle}"
                    Margin="0,0,0,10"/>

                <!-- Botones -->

                <Button Content="Registrar"
                        Command="{Binding GuardarCommand}"
                        Padding="6"
                        Margin="0,0,0,5"
                        ToolTip="Crear o modificar un plato">

                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#B2D4A373" Offset="0"/>
                            <GradientStop Color="#FFD4A373" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>

                </Button>

                <Button Content="Eliminar"
                        Command="{Binding EliminarCommand}"
                        Padding="6"
                        Margin="0,0,0,5"
                        ToolTip="Eliminar plato seleccionado">

                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#B2D4A679" Offset="0"/>
                            <GradientStop Color="#FFD4A679" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>

                </Button>

                <Button Content="Cambiar Disponibilidad"
                        Command="{Binding ToggleDisponibilidadCommand}"
                        Padding="6"
                        Margin="0,0,0,5"
                        ToolTip="Cambiar disponibilidad del plato">

                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#B2D5AD86" Offset="0"/>
                            <GradientStop Color="#FFD4A97F" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>

                </Button>

                <Button Content="Limpiar"
                        Command="{Binding NuevoCommand}"
                        Padding="6"
                        Margin="0,0,0,10"
                        ToolTip="Limpiar formulario">

                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#B2D4AA81" Offset="0"/>
                            <GradientStop Color="#FFD5AC85" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>

                </Button>

                <TextBlock
                    Text="{Binding Mensaje}"
                    Foreground="{StaticResource TextColor}"
                    TextWrapping="Wrap"/>

            </StackPanel>

        </GroupBox>

    </Grid>

</UserControl>