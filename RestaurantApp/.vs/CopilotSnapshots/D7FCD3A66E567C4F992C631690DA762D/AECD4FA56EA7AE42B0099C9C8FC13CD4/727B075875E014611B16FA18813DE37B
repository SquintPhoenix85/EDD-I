<UserControl x:Class="RestaurantApp.Views.MesasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>

        <!-- Estilo para contenedor de mesa con overlay -->
        <Style x:Key="MesaContainerStyle" TargetType="Grid">
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="160"/>
            <Setter Property="Height" Value="160"/>
        </Style>

        <!-- Estilo para la imagen de mesa -->
        <Style x:Key="MesaImageStyle" TargetType="Image">
            <Setter Property="Stretch" Value="UniformToFill"/>
            <Setter Property="Opacity" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Estilo para información superpuesta -->
        <Style x:Key="MesaInfoOverlayStyle" TargetType="Border">
            <Setter Property="Background" Value="#00000000"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CC000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Plano del Restaurante -->
        <GroupBox Header="Plano del Restaurante"
                  Grid.Column="0"
                  Margin="0,0,5,0"
                  FontFamily="/Fonts/#Poppins"
                  FontWeight="Bold">

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Mesas}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" 
                                       HorizontalAlignment="Left"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Contenedor principal de la mesa -->
                            <Grid Style="{StaticResource MesaContainerStyle}"
                                  MouseLeftButtonUp="Mesa_MouseLeftButtonUp">

                                <!-- Imagen de la mesa basada en capacidad -->
                                <Image Source="{Binding Capacidad, Converter={StaticResource CapacidadToMesaImageConverter}}"
                                       Style="{StaticResource MesaImageStyle}"/>

                                <!-- Borde de selección (visible si está seleccionada) -->
                                <Border BorderThickness="3" 
                                        BorderBrush="#FFD700"
                                        CornerRadius="4"
                                        Opacity="0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl}, Path=DataContext.SelectedMesa}" Value="{Binding .}">
                                                    <Setter Property="Opacity" Value="1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <!-- Overlay de información en la parte inferior -->
                                <Border Style="{StaticResource MesaInfoOverlayStyle}">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                                        <!-- Número de Mesa -->
                                        <TextBlock Text="{Binding Numero, StringFormat='Mesa {0}'}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="White"
                                                   TextAlignment="Center"
                                                   Margin="0,0,0,2"/>

                                        <!-- Estado con color dinámico -->
                                        <TextBlock FontSize="11"
                                                   Foreground="White"
                                                   TextAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding Estado}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Estado}" Value="Libre">
                                                            <Setter Property="Foreground" Value="#90EE90"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Estado}" Value="Ocupada">
                                                            <Setter Property="Foreground" Value="#FF6B6B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                    </StackPanel>
                                </Border>

                            </Grid>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </GroupBox>

        <!-- Gestión de Mesa -->
        <GroupBox Header="Gestión de Mesa"
                  Grid.Column="1"
                  FontFamily="/Fonts/#Poppins"
                  FontWeight="Bold">
            <StackPanel Margin="10" VerticalAlignment="Top">
                <Label Content="Número:" Foreground="{StaticResource TextColor}" FontWeight="Regular"/>
                <TextBox Text="{Binding Numero, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <Label Content="Capacidad:" Foreground="{StaticResource TextColor}" FontWeight="Regular"/>
                <TextBox Text="{Binding Capacidad, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                <Button Content="Guardar" Command="{Binding GuardarCommand}" Margin="0,0,0,5" Padding="6"/>
                <Button Content="Eliminar" Command="{Binding EliminarCommand}" Margin="0,0,0,5" Padding="6"/>
                <Button Content="Nuevo" Command="{Binding NuevoCommand}" Margin="0,0,0,10" Padding="6"/>

                <TextBlock Text="{Binding Mensaje}" 
                           Foreground="{StaticResource TextColor}" 
                           TextWrapping="Wrap"/>
            </StackPanel>
        </GroupBox>
    </Grid>

</UserControl>
