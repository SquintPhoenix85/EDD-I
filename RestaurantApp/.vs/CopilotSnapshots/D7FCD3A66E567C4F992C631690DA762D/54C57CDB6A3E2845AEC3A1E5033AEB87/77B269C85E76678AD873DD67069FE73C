<UserControl x:Class="RestaurantApp.Views.PlatosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>

        <!-- Estilo para TextBox -->
        <Style x:Key="CustomTextBoxStyle" TargetType="TextBox">

            <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="3"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>

            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#33D4A373" Offset="0"/>
                        <GradientStop Color="#66D4A373" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="#66D4A373"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">

                                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Stretch"/>           
                        </Border>


                    <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#4CD4A373" Offset="0"/>
                                            <GradientStop Color="#80D4A373" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                        
                            <!-- Focus -->
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#66D4A373" Offset="0"/>
                                            <GradientStop Color="#99D4A373" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>

        <!-- Estilo para Tarjetas de Platos -->
        <Style x:Key="PlatoCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D4A373"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#6F4E37"/>
                    <Setter Property="BorderThickness" Value="3"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Lista de platos -->
        <GroupBox Header="Lista de Platos"
                  Grid.Column="0"
                  Margin="0,0,5,0"
                  FontFamily="/Fonts/#Poppins"
                  FontWeight="Bold">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Platos}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" 
                                       HorizontalAlignment="Left"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource PlatoCardStyle}"
                                    Width="180"
                                    MouseLeftButtonUp="Border_MouseLeftButtonUp">
                                <StackPanel VerticalAlignment="Top">

                                    <!-- Imagen -->
                                    <Image Source="{Binding Nombre, Converter={StaticResource PlatoNameToImageConverter}}"
                                           Width="156"
                                           Height="100"
                                           Stretch="UniformToFill"
                                           VerticalAlignment="Top"
                                           Margin="0,0,0,8"/>

                                    <!-- ID -->
                                    <TextBlock Text="{Binding Id, StringFormat='ID: {0}'}"
                                               FontSize="10"
                                               Foreground="#999999"
                                               Margin="0,0,0,4"/>

                                    <!-- Nombre -->
                                    <TextBlock Text="{Binding Nombre}"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="#2D2D2D"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,8"/>

                                    <!-- Precio -->
                                    <TextBlock Text="{Binding Precio, StringFormat='${0:N2}'}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#6F4E37"
                                               Margin="0,0,0,8"/>

                                    <!-- Disponibilidad -->
                                    <Border CornerRadius="4"
                                            Padding="6,3"
                                            Background="{Binding Disponible, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#90EE90|#FFB6C6'}">
                                        <TextBlock Text="{Binding Disponible, Converter={StaticResource BoolToTextConverter}, ConverterParameter='Disponible|No disponible'}"
                                                   FontSize="11"
                                                   Foreground="#FFFFFF"
                                                   TextAlignment="Center"
                                                   FontWeight="Bold"/>
                                    </Border>

                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </GroupBox>

        <!-- Formulario -->
        <GroupBox Header="Gestión de Plato"
                  Grid.Column="1"
                  FontFamily="/Fonts/#Poppins"
                  FontWeight="Bold">

            <StackPanel Margin="10">

                <Label Content="Nombre:"
                       Foreground="{StaticResource TextColor}"
                       FontWeight="Regular"/>

                <TextBox
                    Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"
                    Style="{StaticResource CustomTextBoxStyle}"
                    Margin="0,0,0,10"/>

                <Label Content="Precio:"
                       Foreground="{StaticResource TextColor}"
                       FontWeight="Regular"/>

                <TextBox
                    Text="{Binding Precio, UpdateSourceTrigger=PropertyChanged}"
                    Style="{StaticResource CustomTextBoxStyle}"
                    Margin="0,0,0,10"/>

                <Label Content="URL Imagen:"
                       Foreground="{StaticResource TextColor}"
                       FontWeight="Regular"/>

                <TextBox
                    Text="{Binding ImagePath, UpdateSourceTrigger=PropertyChanged}"
                    Style="{StaticResource CustomTextBoxStyle}"
                    Margin="0,0,0,10"/>

                <!-- Botones -->

                <Button Content="Registrar"
                        Command="{Binding GuardarCommand}"
                        Padding="6"
                        Margin="0,0,0,5"
                        ToolTip="Crear o modificar un plato">

                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#B2D4A373" Offset="0"/>
                            <GradientStop Color="#FFD4A373" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>

                </Button>

                <Button Content="Eliminar"
                        Command="{Binding EliminarCommand}"
                        Padding="6"
                        Margin="0,0,0,5"
                        ToolTip="Eliminar plato seleccionado">

                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#B2D4A679" Offset="0"/>
                            <GradientStop Color="#FFD4A679" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>

                </Button>

                <Button Content="Cambiar Disponibilidad"
                        Command="{Binding ToggleDisponibilidadCommand}"
                        Padding="6"
                        Margin="0,0,0,5"
                        ToolTip="Cambiar disponibilidad del plato">

                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#B2D5AD86" Offset="0"/>
                            <GradientStop Color="#FFD4A97F" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>

                </Button>

                <Button Content="Limpiar"
                        Command="{Binding NuevoCommand}"
                        Padding="6"
                        Margin="0,0,0,10"
                        ToolTip="Limpiar formulario">

                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#B2D4AA81" Offset="0"/>
                            <GradientStop Color="#FFD5AC85" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>

                </Button>

                <TextBlock
                    Text="{Binding Mensaje}"
                    Foreground="{StaticResource TextColor}"
                    TextWrapping="Wrap"/>

            </StackPanel>

        </GroupBox>

    </Grid>

</UserControl>