namespace RestaurantApp.Utilities
{
    public static class PlatoImageHelper
    {
        /// <summary>
        /// Obtiene la ruta de imagen para un plato. Si el plato no tiene imagen, retorna la imagen por defecto.
        /// </summary>
        public static string GetImagePath(string? imagePath)
        {
            if (!string.IsNullOrEmpty(imagePath))
                return imagePath;
            
            // Imagen por defecto si no hay imagen asignada
            return "pack://application:,,,/Resources/Images/plato-default.png";
        }

        /// <summary>
        /// Verifica si una imagen existe en el proyecto.
        /// </summary>
        public static bool ImageExists(string? imagePath)
        {
            if (string.IsNullOrEmpty(imagePath))
                return false;

            // Convertir ruta de recurso a ruta del sistema de archivos
            var localPath = imagePath.Replace("pack://application:,,,/", "");
            return File.Exists(localPath);
        }

        /// <summary>
        /// Obtiene una lista de rutas de imagen disponibles.
        /// </summary>
        public static List<string> GetAvailableImages()
        {
            var imageDir = "Resources/Images/platos";
            var images = new List<string>();

            if (Directory.Exists(imageDir))
            {
                var files = Directory.GetFiles(imageDir, "*.png")
                    .Concat(Directory.GetFiles(imageDir, "*.jpg"))
                    .Concat(Directory.GetFiles(imageDir, "*.jpeg"));

                foreach (var file in files)
                {
                    var fileName = Path.GetFileName(file);
                    images.Add($"/Resources/Images/platos/{fileName}");
                }
            }

            return images;
        }
    }
}
