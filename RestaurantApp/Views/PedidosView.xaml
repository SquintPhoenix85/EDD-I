<UserControl x:Class="RestaurantApp.Views.PedidosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Crear pedido -->
        <GroupBox Header="Crear Pedido" Grid.Row="0" Margin="0,0,0,5">
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label Content="Mesa:" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding Mesas}" SelectedItem="{Binding SelectedMesa}"
                          DisplayMemberPath="Numero" Width="100" Margin="5,0"/>
                <Button Content="Crear Pedido" Command="{Binding CrearPedidoCommand}" Padding="8,3"/>
            </StackPanel>
        </GroupBox>

        <!-- Lista de pedidos y detalles -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Pedidos" Grid.Column="0" Margin="0,0,5,0">
                <DataGrid ItemsSource="{Binding Pedidos}" SelectedItem="{Binding SelectedPedido}"
                          AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                        <DataGridTextColumn Header="Mesa" Binding="{Binding MesaNumero}" Width="50"/>
                        <DataGridTextColumn Header="Fecha" Binding="{Binding FechaHora, StringFormat=dd/MM/yyyy HH:mm}" Width="130"/>
                        <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="80"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=C}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox Header="Detalles del Pedido" Grid.Column="1">
                <DataGrid ItemsSource="{Binding Detalles}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Plato" Binding="{Binding NombrePlato}" Width="*"/>
                        <DataGridTextColumn Header="Cant." Binding="{Binding Cantidad}" Width="50"/>
                        <DataGridTextColumn Header="P.Unit." Binding="{Binding PrecioUnitario, StringFormat=C}" Width="80"/>
                        <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=C}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>

        <!-- Acciones -->
        <GroupBox Header="Acciones" Grid.Row="2" Margin="0,5,0,0">
            <WrapPanel Margin="5">
                <Label Content="Plato:" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding Platos}" SelectedItem="{Binding SelectedPlato}"
                          DisplayMemberPath="Nombre" Width="124" SelectionChanged="ComboBox_SelectionChanged" Height="47" RenderTransformOrigin="-0.053,0.518" HorizontalContentAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Label Content="Cantidad:" VerticalAlignment="Center"/>
                <TextBox Text="{Binding Cantidad, UpdateSourceTrigger=PropertyChanged}" Width="80" Margin="5,0"/>
                <Button Content="Agregar Plato" Command="{Binding AgregarDetalleCommand}" Margin="5,0" Padding="8,3"/>
                <Label Content="Propina %:" VerticalAlignment="Center"/>
                <TextBox Text="{Binding Propina, UpdateSourceTrigger=PropertyChanged}" Width="80" Margin="5,0"/>
                <Button Content="Cerrar Pedido" Command="{Binding CerrarPedidoCommand}" Margin="5,0" Padding="8,3"/>
                <Button Content="Cancelar Pedido" Command="{Binding CancelarPedidoCommand}" Margin="5,0" Padding="8,3"/>
                <Button Content="Generar Factura" Command="{Binding GenerarFacturaCommand}" Margin="5,0" Padding="8,3"/>
                <TextBlock Text="{Binding Mensaje}" Foreground="DarkGreen" VerticalAlignment="Center" Margin="10,0" TextWrapping="Wrap"/>
            </WrapPanel>
        </GroupBox>
    </Grid>
</UserControl>
