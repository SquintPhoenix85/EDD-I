<UserControl x:Class="RestaurantApp.Views.ReportesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Filtros -->
        <GroupBox Header="Filtros" Grid.Row="0" Margin="0,0,0,5">
            <StackPanel Orientation="Horizontal" Margin="5">
                <Label Content="Desde:" VerticalAlignment="Center"/>
                <DatePicker SelectedDate="{Binding FechaInicio}" Width="130" Margin="5,0"/>
                <Label Content="Hasta:" VerticalAlignment="Center"/>
                <DatePicker SelectedDate="{Binding FechaFin}" Width="130" Margin="5,0"/>
                <Button Content="Ventas por Fecha" Command="{Binding GenerarVentasCommand}" Margin="5,0" Padding="8,3"/>
                <Button Content="Top 5 Platos" Command="{Binding GenerarTopPlatosCommand}" Margin="5,0" Padding="8,3"/>
                <TextBlock Text="{Binding Mensaje}" Foreground="DarkGreen" VerticalAlignment="Center" Margin="10,0"/>
            </StackPanel>
        </GroupBox>

        <!-- Ventas por fecha -->
        <GroupBox Header="Ventas por Rango de Fechas" Grid.Row="1" Margin="0,0,0,5">
            <DataGrid ItemsSource="{Binding Ventas}" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=dd/MM/yyyy}" Width="120"/>
                    <DataGridTextColumn Header="# Facturas" Binding="{Binding NumeroFacturas}" Width="100"/>
                    <DataGridTextColumn Header="Total Ventas" Binding="{Binding TotalVentas, StringFormat=C}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- Top platos -->
        <GroupBox Header="Top 5 Platos Más Vendidos" Grid.Row="2">
            <DataGrid ItemsSource="{Binding TopPlatos}" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Plato" Binding="{Binding NombrePlato}" Width="*"/>
                    <DataGridTextColumn Header="Cantidad" Binding="{Binding CantidadVendida}" Width="100"/>
                    <DataGridTextColumn Header="Total Generado" Binding="{Binding TotalGenerado, StringFormat=C}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</UserControl>
