<UserControl x:Class="RestaurantApp.Views.FacturasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <GroupBox Header="Facturas" Margin="10">
        <DataGrid ItemsSource="{Binding Facturas}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Pedido" Binding="{Binding PedidoId}" Width="60"/>
                <DataGridTextColumn Header="Mesa" Binding="{Binding MesaNumero}" Width="60"/>
                <DataGridTextColumn Header="Fecha" Binding="{Binding FechaHora, StringFormat=dd/MM/yyyy HH:mm}" Width="130"/>
                <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=C}" Width="100"/>
                <DataGridTextColumn Header="Propina" Binding="{Binding Propina, StringFormat=C}" Width="100"/>
                <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=C}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </GroupBox>
</UserControl>
