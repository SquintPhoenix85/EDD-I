<UserControl x:Class="RestaurantApp.Views.PlatosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        
        <!-- Lista de platos -->
        <GroupBox Header="Lista de Platos" Grid.RowSpan="3"  Grid.Column="0" Margin="0,0,5,0">
            <DataGrid ItemsSource="{Binding Platos}" SelectedItem="{Binding SelectedPlato}"
                      AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                    <DataGridTextColumn Header="Precio" Binding="{Binding Precio, StringFormat=C}" Width="100"/>
                    <DataGridTextColumn Header="Disponible" Binding="{Binding Disponible}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- Formulario -->
        <GroupBox Header="Gestión de Plato" Grid.Column="1">
            <StackPanel Margin="10" VerticalAlignment="Top">
                <Label Content="Nombre:"/>
                <TextBox Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                <Label Content="Precio:"/>
                <TextBox Text="{Binding Precio, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                <Button Content="Registrar" Command="{Binding GuardarCommand}" Margin="0,0,0,5" Padding="5" ToolTip="Use este botón para crear un nuevo plato, o modificar las propiedades de uno existente."/>
                <Button Content="Eliminar" Command="{Binding EliminarCommand}" Margin="0,0,0,5" Padding="5" ToolTip="Seleccione una entrada en la tabla, y clickee aquí para eliminarla."/>
                <Button Content="Cambiar Disponibilidad" Command="{Binding ToggleDisponibilidadCommand}" Margin="0,0,0,5" Padding="5" ToolTip="Registra la disponibilidad del plato en las entradas de facturación."/>
                <Button Content="Limpiar" Command="{Binding NuevoCommand}" Margin="0,0,0,5" Padding="5" ToolTip="Use este botón para despejar los campos del formulario."/>
                <TextBlock Text="{Binding Mensaje}" Foreground="LightBlue" TextWrapping="Wrap"/>
            </StackPanel>
        </GroupBox>
    </Grid>
</UserControl>
