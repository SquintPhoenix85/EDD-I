<Window x:Class="RestaurantApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:RestaurantApp.Views"
        xmlns:vm="clr-namespace:RestaurantApp.ViewModels"
        Title="Sistema de Gestión de Restaurante" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">
    <TabControl SelectionChanged="TabControl_SelectionChanged">
        <TabItem Header="🍽️ Platos">
            <views:PlatosView DataContext="{Binding PlatosVM}"/>
        </TabItem>
        <TabItem Header="🪑 Mesas">
            <views:MesasView DataContext="{Binding MesasVM}"/>
        </TabItem>
        <TabItem Header="📋 Pedidos">
            <views:PedidosView DataContext="{Binding PedidosVM}"/>
        </TabItem>
        <TabItem Header="🧾 Facturas">
            <views:FacturasView DataContext="{Binding FacturasVM}"/>
        </TabItem>
        <TabItem Header="📊 Reportes">
            <views:ReportesView DataContext="{Binding ReportesVM}"/>
        </TabItem>
    </TabControl>
</Window>
